# Copy to .env at repo root and adjust as needed.

# ---- Postgres ----
POSTGRES_USER=confeccao
POSTGRES_PASSWORD=confeccao
POSTGRES_DB=confeccao
POSTGRES_PORT=5433

# ---- Backend ----
BACKEND_PORT=5080
# Set to "true" on first boot to insert sample orders/users so the dashboard isn't empty.
SEED_SAMPLE_DATA=false

# ---- Frontend ----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:5080
